\line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u160 2 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1072 }\cell

