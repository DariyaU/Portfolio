\pard\intbl\itap1\sl260{\fs18\cf1\uc0\u1057 \uc0\u1072 \uc0\u1085 \uc0\u1082 \uc0\u1090 -\uc0\u1055 \uc0\u1077 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1073 \uc0\u1091 \uc0\u1088 \uc0\u1075 }\par


\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1056 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100  \uc0\u1086 \uc0\u1073 \uc0\u1097 \uc0\u1077 \uc0\u1075 \uc0\u1086  \uc0\u1086 \uc0\u1090 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1072  \uc0\u1072 \uc0\u1076 \uc0\u1084 \uc0\u1080 \uc0\u1085 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1089 \uc0\u1083 \uc0\u1091 \uc0\u1078 \uc0\u1073 \uc0\u1099 \par}

\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1050 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 , \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1091 \uc0\u1102 \uc0\u1097 \uc0\u1072 \uc0\u1103 \uc0\u1089 \uc0\u1103  \uc0\u1085 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1077  \uc0\u1078 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1081  \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1074 \uc0\u1080 \uc0\u1078 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080  \uc0\u1080  \uc0\u1072 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1076 \uc0\u1077  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1084 \uc0\u1077 \uc0\u1088 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1087 \uc0\u1086 \uc0\u1084 \uc0\u1077 \uc0\u1097 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081  {\line}{\line}\uc0\u1054 \uc0\u1073 \uc0\u1103 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080  \uc0\u1080  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 : {\line}-\uc0\u1054 \uc0\u1087 \uc0\u1090 \uc0\u1080 \uc0\u1084 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1073 \uc0\u1080 \uc0\u1079 \uc0\u1085 \uc0\u1077 \uc0\u1089 -\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1086 \uc0\u1074  (\uc0\u1084 \uc0\u1099 \uc0\u1096 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1072 ) {\line}- \uc0\u1050 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1100  \uc0\u1082 \uc0\u1072 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  {\line}- \uc0\u1056 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072  \uc0\u1089  \uc0\u1073 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1096 \uc0\u1080 \uc0\u1084 \uc0\u1080  \uc0\u1086 \uc0\u1073 \uc0\u1098 \uc0\u1105 \uc0\u1084 \uc0\u1072 \uc0\u1084 \uc0\u1080  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  {\line}- \uc0\u1054 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1080  \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1100  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1090 \uc0\u1072  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1080 : \uc0\u1088 \uc0\u1077 \uc0\u1075 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 , \uc0\u1091 \uc0\u1095 \uc0\u1105 \uc0\u1090 , \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1074 \uc0\u1093 \uc0\u1086 \uc0\u1076 \uc0\u1103 \uc0\u1097 \uc0\u1077 \uc0\u1081 /\uc0\u1080 \uc0\u1089 \uc0\u1093 \uc0\u1086 \uc0\u1076 \uc0\u1103 \uc0\u1097 \uc0\u1077 \uc0\u1081  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1084 \uc0\u1077 \uc0\u1078 \uc0\u1076 \uc0\u1091  \uc0\u1086 \uc0\u1090 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1084 \uc0\u1080 .{\line}- \uc0\u1059 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1086 \uc0\u1081 : \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1105 \uc0\u1084 , \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 , \uc0\u1086 \uc0\u1094 \uc0\u1080 \uc0\u1092 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 , \uc0\u1086 \uc0\u1073 \uc0\u1077 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080 \uc0\u1093  \uc0\u1089 \uc0\u1086 \uc0\u1093 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080  \uc0\u1080  \uc0\u1089 \uc0\u1074 \uc0\u1086 \uc0\u1077 \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1074 \uc0\u1099 \uc0\u1076 \uc0\u1072 \uc0\u1095 \uc0\u1080 ; \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1091 \uc0\u1090 \uc0\u1080 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1074  \uc0\u1089 \uc0\u1086 \uc0\u1086 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1090 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1080 \uc0\u1080  \uc0\u1089  \uc0\u1088 \uc0\u1077 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1084 .{\line}- \uc0\u1050 \uc0\u1086 \uc0\u1086 \uc0\u1088 \uc0\u1076 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \uc0\u1086 \uc0\u1090 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1072 : \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095 , \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1100  \uc0\u1089 \uc0\u1088 \uc0\u1086 \uc0\u1082 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1082 \uc0\u1072 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1072  \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 , \uc0\u1084 \uc0\u1086 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1089 \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1074 .{\line}- \uc0\u1054 \uc0\u1073 \uc0\u1091 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1089 \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1074 : \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1074 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1072 \uc0\u1078 \uc0\u1077 \uc0\u1081 , \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1087 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1072  \uc0\u1082  \uc0\u1074 \uc0\u1085 \uc0\u1091 \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1080 \uc0\u1084  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1072 \uc0\u1084  \uc0\u1080  \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1072 \uc0\u1088 \uc0\u1090 \uc0\u1072 \uc0\u1084 .{\line}- \uc0\u1052 \uc0\u1077 \uc0\u1078 \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1086 \uc0\u1084 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1074 \uc0\u1079 \uc0\u1072 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1080 \uc0\u1077 : \uc0\u1086 \uc0\u1073 \uc0\u1077 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1083 \uc0\u1072 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \uc0\u1084 \uc0\u1077 \uc0\u1078 \uc0\u1076 \uc0\u1091  \uc0\u1072 \uc0\u1076 \uc0\u1084 \uc0\u1080 \uc0\u1085 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1099 \uc0\u1084 , \uc0\u1102 \uc0\u1088 \uc0\u1080 \uc0\u1076 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1084 , \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1084 \uc0\u1077 \uc0\u1088 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1084  \uc0\u1080  \uc0\u1076 \uc0\u1088 \uc0\u1091 \uc0\u1075 \uc0\u1080 \uc0\u1084 \uc0\u1080  \uc0\u1086 \uc0\u1090 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1084 \uc0\u1080 .{\line}\uc0\u1044 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 :{\line}- \uc0\u1057 \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1083 \uc0\u1072  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103  \uc0\u1087 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1072  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1085 \uc0\u1072  30% {\line}- \uc0\u1055 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1089 \uc0\u1080 \uc0\u1083 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1090 \uc0\u1072 }

\cell\row
